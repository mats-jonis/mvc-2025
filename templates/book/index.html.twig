{% extends 'base.html.twig' %}

{% block title %}Book index{% endblock %}

{% block main %}
<div class="library">
    <h1>Library</h1>
    <p class="library-intro">A book database built with Symfony and Doctrine ORM.</p>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Title</th>
                <th>Isbn</th>
                <th>Author</th>
                <th>Cover</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for book in books %}
            <tr>
                <td>{{ book.id }}</td>
                <td>{{ book.title }}</td>
                <td>{{ book.isbn }}</td>
                <td>{{ book.author }}</td>
                <td>
                    <img src="{{ asset('images/books/' ~ book.img) }}" alt="{{ book.title }}">
                </td>
                <td>
                    <a href="{{ path('library_book_show', {'id': book.id}) }}">show</a>
                    <a href="{{ path('library_book_edit', {'id': book.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('library_create') }}">Create new</a>
</div>
{% endblock %}
