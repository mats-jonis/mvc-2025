{% extends "base.html.twig" %}
{% block title %}Game 21{% endblock %}
{% block main %}
<h1>Game 21</h1>
{{ include('flash.html.twig') }}
<div class="game-landing">
  <div class="rules-card">
    <h2>How to play</h2>
    <ul>
      <li>Aces are worth 1 or 14. Jack, Queen and King are worth 10; all other cards keep their value.</li>
      <li>Draw cards one at a time and stand when you're happy with your hand.</li>
      <li>The bank then draws until it reaches 17 or more.</li>
      <li>You win if your hand beats the bank's or the bank goes over 21. The bank wins on a tie or if you go over 21.</li>
    </ul>
  </div>

  <form method="post" action="{{ path('game_init') }}">
    <button type="submit" class="btn-play">Start a new game</button>
  </form>

  <a class="doc-link" href="{{ path('game_doc') }}">Read the documentation →</a>
</div>
{% endblock %}